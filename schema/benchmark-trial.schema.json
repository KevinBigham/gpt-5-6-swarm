{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/KevinBigham/gpt-5-6-swarm/schema/benchmark-trial.schema.json",
  "title": "GPT-5.6 Swarm benchmark trial",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "benchmark_schema_version", "case_sha256", "trial_id", "pair_id",
    "arm", "replicate", "order", "warmup", "host_profile_sha256",
    "routing_status", "duration_ns", "timing_source", "terminal_status",
    "acceptance_passed", "gate_sha256", "artifact_sha256",
    "requested_parallel", "scheduler_issued_peak", "observed_peak",
    "telemetry_sha256", "usage", "unknowns", "retries",
    "exclusion_reason", "evidence"
  ],
  "properties": {
    "benchmark_schema_version": {"const": 1},
    "case_sha256": {"$ref": "#/$defs/sha256"},
    "trial_id": {"$ref": "#/$defs/id"},
    "pair_id": {"$ref": "#/$defs/id"},
    "arm": {"enum": ["serial", "swarm"]},
    "replicate": {"type": "integer", "minimum": 1},
    "order": {"enum": ["AB", "BA"]},
    "warmup": {"type": "boolean"},
    "host_profile_sha256": {"$ref": "#/$defs/sha256"},
    "routing_status": {"enum": ["pinned", "host_selected"]},
    "duration_ns": {"type": "integer", "minimum": 1},
    "timing_source": {"type": "string", "minLength": 1},
    "terminal_status": {"enum": ["SUCCEEDED", "FAILED", "ABORTED", "CANCELED", "UNKNOWN"]},
    "acceptance_passed": {"type": "boolean"},
    "gate_sha256": {"$ref": "#/$defs/sha256"},
    "artifact_sha256": {"anyOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
    "requested_parallel": {"type": "integer", "minimum": 1},
    "scheduler_issued_peak": {"type": "integer", "minimum": 0},
    "observed_peak": {"anyOf": [{"type": "integer", "minimum": 1}, {"type": "null"}]},
    "telemetry_sha256": {"anyOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_tokens", "output_tokens", "credits", "source"],
      "properties": {
        "input_tokens": {"anyOf": [{"type": "integer", "minimum": 0}, {"type": "null"}]},
        "output_tokens": {"anyOf": [{"type": "integer", "minimum": 0}, {"type": "null"}]},
        "credits": {"anyOf": [{"type": "integer", "minimum": 0}, {"type": "null"}]},
        "source": {"anyOf": [{"type": "string", "minLength": 1}, {"type": "null"}]}
      }
    },
    "unknowns": {"type": "integer", "minimum": 0},
    "retries": {"type": "integer", "minimum": 0},
    "exclusion_reason": {"anyOf": [{"type": "string", "minLength": 1}, {"type": "null"}]},
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ledger", "journal", "doctor", "gate_log", "timing"],
      "properties": {
        "ledger": {"$ref": "#/$defs/sha256"},
        "journal": {"$ref": "#/$defs/sha256"},
        "doctor": {"$ref": "#/$defs/sha256"},
        "gate_log": {"$ref": "#/$defs/sha256"},
        "timing": {"$ref": "#/$defs/sha256"}
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"}
  }
}
